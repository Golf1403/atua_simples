  "scripts": {
    "deploy-prod": "yarn build && aws s3 cp build/ s3://sei.app.br --recursive && aws cloudfront create-invalidation --distribution-id E2QF6P0JR5UZBZ --paths \"/*\"",
    "deploy-hml": "yarn build && aws s3 cp build/ s3://hml.sei.app.br --recursive && aws cloudfront create-invalidation --distribution-id ESUNZA0L3FWBW --paths \"/*\"",
    "deploy-dev": "yarn build && aws s3 cp build/ s3://dev.sei.app.br --recursive && aws cloudfront create-invalidation --distribution-id E3LF65M4ACPFQ6 --paths \"/*\"",
    "postbuild": "sh run.sh --aws-configure-container",
    "start": "react-app-rewired start",
    "build": "react-app-rewired build",
    "react-test": "react-app-rewired test",
    "test": "AWS_SDK_JS_SUPPRESS_MAINTENANCE_MODE_MESSAGE=1 jest --maxWorkers=50%",
    "test:watch": "jest --watch --maxWorkers=25%",
    "test:ci": "jest --runInBand",
    "test:coverage": "jest --coverage --coverageReporters='text-summary'",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix src",
    "eject": "react-scripts eject"
  },
  "browserslist": {
